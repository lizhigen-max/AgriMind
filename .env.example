
# deepseek 模型名称
DEEPSEEK_NAME="deepseek:deepseek-chat"

# deepseek 秘钥
DEEPSEEK_API_KEY="你的模型秘钥"

# bge_large_zh 本地路径
BGE_LARGE_ZH_MODEL_PATH="./models/BAAI/bge-large-zh-v1.5"

# BGE_M3 本地路径
BGE_M3__MODEL_PATH="./models/BAAI/bge-m3"

# device: cpu/cuda
DEVICE="cpu"

# 向量模型是否归一化
NOR_EBDINGS=true

# bge_large_zh 向量数据库保存位置
VEC_DB_BGE_LARGE_ZH_PATH="./data/vector_db_bge_large_zh"

# bge_m3 向量数据库保存位置
VEC_DB_BGE_M3_PATH="./data/vector_db_bge_m3"

# faiss vector_index
VEC_INDEX="vector_index"

# chroma collection_name
COLL_NAME="chroma_collection"

# milvus设置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=default
MILVUS_COLLECTION_NAME=rag_collection

# 可选：Milvus 索引参数（JSON格式，可选）
MILVUS_INDEX_PARAMS={"metric_type": "L2", "index_type": "IVF_FLAT", "params": {"nlist": 128}}
MILVUS_SEARCH_PARAMS={"metric_type": "L2", "params": {"nprobe": 10}}

# VectorDBType 向量数据库类型：faiss、chroma、milvus
VECTORDBTYPE="milvus"

# 是否开启RAG缓存
ENABLED_RAG_CACHE=false

# RAG缓存数据库地址
RAG_CACHE_DB_PATH="./data/vector_cache.db"

# RAG缓存有效周期（天）
RAG_CACHE_EXPIRE_DAYS=7

# RAG缓存最大内存（MB）
RAG_CACHE_MAX_SIZE=1024

# 是否开启重排序
RERANKER_ENABLED=true

# 重排序模型位置
RERANKER_MODEL_PATH="./models/BAAI/bge-reranker-base"

# 重排序模型的置信度阈值，超过这个值才返回threshold
RERANKER_THRESHOLD=0.1

# 重排序模型的最大输入长度
RERANKER_MAX_LEN=512

# 向量检索得到几个内容
VECTOR_K=8

# 关键字检索得到几个内容
BM25_K=8

# 混合检索中关键字检索权重
ENSEMBLE_WGT_BM25=0.3

# 混合检索中关键字检索权重
ENSEMBLE_WGT_VECTOR=0.7

# 是否开启异步
USE_ASYNC = false


# 日志保存路径
LOG_PATH="./log/Agent.log"

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 开发模式（true/false）
DEV_MODE=true

# 最大重试次数
MAX_RETRIES=3

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 默认温度参数（0.0 - 2.0）
DEFAULT_TEMPERATURE=0.7

# 默认最大 Token 数
DEFAULT_MAX_TOKENS=2000

